    "motion": "^12.38.0",
    "tailwind-merge": "^3.5.0",
    "typed.js": "^3.0.0"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "cross-env": "^10.1.0",
    "tailwindcss": "^4.2.2",
    "vite": "^6.3.5",
    "vitest": "^4.1.5",
    "wrangler": "^4.4.0"
